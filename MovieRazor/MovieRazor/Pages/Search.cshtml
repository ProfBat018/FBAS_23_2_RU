@page
@model MovieRazor.Pages.Search

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="text-center mb-4">Поиск фильма</h2>

            <form method="post">
                <div class="input-group">
                    <input type="text" name="title" class="form-control" placeholder="Введите название фильма" aria-label="Название фильма">
                    <button class="btn btn-primary" type="submit">Искать</button>
                </div>
            </form>
        </div>
    </div>
    
    @if (Model.SearhByTitleRes != null && Model.SearhByTitleRes.results.Length > 0)
    {
        <div class="container mt-5">
            <div class="row">
                @foreach (var movie in Model.SearhByTitleRes.results)
                {
                   <partial name="Shared/_MoviePartial" model="movie"/>
                }
            </div>
        </div>
    }
</div>